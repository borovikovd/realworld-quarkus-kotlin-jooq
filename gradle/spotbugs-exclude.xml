<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude OpenAPI generated code -->
    <Match>
        <Package name="~com\.example\.api(\..*)?"/>
    </Match>

    <!-- Exclude jOOQ generated code -->
    <Match>
        <Package name="~com\.example\.jooq(\..*)?"/>
    </Match>

    <!-- Kotlin false positives: mutable field exposure (data classes, DI) -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>

    <!-- Kotlin false positives: List/Collection casts (Kotlin List compiles to java.util.List) -->
    <Match>
        <Bug pattern="BC_BAD_CAST_TO_ABSTRACT_COLLECTION"/>
    </Match>

    <!-- Kotlin false positives: lateinit var with @Inject -->
    <Match>
        <Bug pattern="NP_NONNULL_RETURN_VIOLATION"/>
    </Match>
    <Match>
        <Bug pattern="PA_PUBLIC_PRIMITIVE_ATTRIBUTE"/>
    </Match>

    <!-- Keyset unwrap in init block throws on bad config at startup — intentional fail-fast behaviour.
         No finalizer on this class; the finalizer-attack vector does not apply. -->
    <Match>
        <Class name="com.example.infrastructure.security.TinkCryptoService"/>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>
</FindBugsFilter>
